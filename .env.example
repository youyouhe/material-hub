# MaterialHub Configuration Example
# Copy this file to .env and modify as needed

# Database (SQLite, relative to backend/)
DB_PATH=data/materials.db

# Server
HOST=0.0.0.0
PORT=8201

# OCR Service
# 后端直接运行在宿主机上，使用localhost即可
# 如果后端在Docker容器中，则需要使用 host.docker.internal:8010
OCR_SERVICE_URL=http://localhost:8010

# OCR请求超时时间（秒），根据OCR服务处理速度调整
# 复杂图片或大图片可能需要更长时间
OCR_TIMEOUT=120

# LLM Provider for Intelligent OCR Extraction
# 支持: deepseek | openrouter | anthropic
LLM_PROVIDER=deepseek

# DeepSeek Configuration
DEEPSEEK_API_KEY=your-deepseek-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# OpenRouter Configuration (如果使用OpenRouter)
# OPENROUTER_API_KEY=sk-or-your-openrouter-api-key
# OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# Anthropic Configuration (如果使用Anthropic直连)
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key
# ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
