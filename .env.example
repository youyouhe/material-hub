# MaterialHub Configuration Example
# Copy this file to .env and modify as needed

# Database (SQLite, relative to backend/)
DB_PATH=data/materials.db

# Server
HOST=0.0.0.0
PORT=8201

# OCR Service
# 后端直接运行在宿主机上，使用localhost即可
# 如果后端在Docker容器中，则需要使用 host.docker.internal:8010
OCR_SERVICE_URL=http://localhost:8010

# OCR请求超时时间（秒），根据OCR服务处理速度调整
# 复杂图片或大图片可能需要更长时间
OCR_TIMEOUT=120

# LLM Provider for Intelligent OCR Extraction
# 支持: deepseek | openrouter | anthropic
LLM_PROVIDER=deepseek

# DeepSeek Configuration
DEEPSEEK_API_KEY=your-deepseek-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# OpenRouter Configuration (如果使用OpenRouter)
# OPENROUTER_API_KEY=sk-or-your-openrouter-api-key
# OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# Anthropic Configuration (如果使用Anthropic直连)
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key
# ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# PostgreSQL for Knowledge Base (Phase 0)
# Used for vector search, knowledge graph, and multi-hop reasoning
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=materialhub_kb
PG_USER=materialhub
PG_PASSWORD=materialhub

# ============================================================
# Embedding Model (独立于聊天LLM，推荐中文场景使用BGE系列)
# ============================================================
# 不配置时会复用 LLM provider 的 base_url + api_key
# 但如果 LLM provider 不支持 /v1/embeddings（如 DeepSeek），
# 建议单独配置 embedding 端点

# 推荐方案1: SiliconFlow (中文最优, BGE-M3)
# EMBEDDING_BASE_URL=https://api.siliconflow.cn
# EMBEDDING_API_KEY=sk-xxx
# EMBEDDING_MODEL=BAAI/bge-m3
# EMBEDDING_DIMENSIONS=4096

# 推荐方案2: 302ai (国内代理，多模型可选)
# EMBEDDING_BASE_URL=https://api.302ai.cn
# EMBEDDING_API_KEY=sk-xxx
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_DIMENSIONS=1536

# 推荐方案3: Jina AI (免费额度，中英双语)
# EMBEDDING_BASE_URL=https://api.jina.ai
# EMBEDDING_API_KEY=jina_xxx
# EMBEDDING_MODEL=jina-embeddings-v3
# EMBEDDING_DIMENSIONS=4096

# 通用配置（不设独立端点时生效）
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIMENSIONS=4096

# Rerank Model (for multi-hop search Phase 3)
RERANK_MODEL=qwen3-rerank

# ===== MCP Server (SSE) — Claude Desktop / LLM 客户端远程连接 =====
# 监听地址：0.0.0.0 = 所有网卡（局域网可访问）；127.0.0.1 = 仅本机
MCP_HOST=0.0.0.0
# 监听端口（改这里后，/reveal 与 mcp_status 给出的 URL 端口会自动跟随）
MCP_PORT=8202
# 传输方式：sse（远程）/ stdio（本地集成）。mcp_start 拉起的 SSE 服务固定用 sse。
MCP_TRANSPORT=sse
# MCP server 回调后端 API 的地址（同机部署保持 localhost 即可）
MATERIALHUB_API_URL=http://localhost:8201
# 对外公布的访问基址：反代/固定域名时填，留空=按浏览器当前访问的 host 动态生成（适合动态 IP / WSL2）
# 例：MCP_PUBLIC_URL=http://mcp.example.com
MCP_PUBLIC_URL=

# ===== 静态 API Key（可选，只读 / 外部集成旧通道，区别于 UI 管理的 SSE token）=====
# 生成：python -c "import secrets; print(secrets.token_hex(32))"
# MATERIALHUB_API_KEY=your-api-key-here          # 只读，宽 folder 访问
# MATERIALHUB_IMPORT_KEY=your-import-key-here     # 导入用，受 folder 权限限制
